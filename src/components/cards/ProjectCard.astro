---
import type { Project } from '../../data/projects';

interface Props {
  project: Project;
}
const { project } = Astro.props;
const { title, meta, body, tags, size, visualLabel } = project;
---
<article class={`proj proj--${size}`}>
  <div class="proj__head">
    <h3 class="proj__title">{title}</h3>
    <span class="proj__meta">{meta}</span>
  </div>
  <p class="proj__body">{body}</p>
  {visualLabel && <div class="proj__visual" data-label={visualLabel}></div>}
  <div class="proj__tags">
    {tags.map((tag) => <span class="proj__tag">{tag}</span>)}
  </div>
</article>
