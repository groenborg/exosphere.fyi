---
import type { Capability } from '../../data/capabilities';

interface Props {
  capability: Capability;
}
const { capability } = Astro.props;
const { num, title, body, icon } = capability;
---
<article class="cap">
  <div class="cap__icon" aria-hidden="true">
    {icon === 'automation' && (
      <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.4">
        <rect x="5" y="9" width="22" height="14" rx="2"/>
        <path d="M9 13l3 3-3 3M14 19h6"/>
      </svg>
    )}
    {icon === 'design' && (
      <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.4">
        <circle cx="16" cy="16" r="9"/>
        <path d="M16 7v18M7 16h18"/>
      </svg>
    )}
    {icon === 'software' && (
      <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.4">
        <path d="M16 6l8 4-8 4-8-4 8-4z"/>
        <path d="M8 14l8 4 8-4M8 20l8 4 8-4"/>
      </svg>
    )}
    {icon === 'experiences' && (
      <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.4">
        <path d="M8 22c0-4 3.5-8 8-8s8 4 8 8"/>
        <circle cx="13" cy="14" r="1.2" fill="currentColor"/>
        <circle cx="19" cy="14" r="1.2" fill="currentColor"/>
        <path d="M16 6v2"/>
      </svg>
    )}
  </div>
  <div class="cap__num">{num}</div>
  <h3 class="cap__title">{title}</h3>
  <p class="cap__body">{body}</p>
</article>
