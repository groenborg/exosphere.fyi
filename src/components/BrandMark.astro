---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<span class={`nav__brand-mark ${className ?? ''}`.trim()} aria-hidden="true">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
    <circle cx="12" cy="12" r="3.6"></circle>
    <ellipse cx="12" cy="12" rx="10.5" ry="4" transform="rotate(-22 12 12)"></ellipse>
  </svg>
</span>
