---
import Button from "../Button.astro";
---
<section class="hero">
  <div class="wrap">
    <div class="hero__inner">
      <div>
        <div class="hero__meta">
          <span class="hero__meta-dot" aria-hidden="true"></span>
          <span>Studio · est. 2014</span>
          <span>·</span>
          <span>Open for new orbits</span>
        </div>
        <h1 class="hero__title">
          We build <em>fun</em><br/>software for<br/>real people.
        </h1>
        <p class="hero__sub">
          Exosphere is a small, joyful studio shipping personal, exciting
          software — automation, design and experiences that put a smile
          on the face of whoever opens them.
        </p>
        <div class="hero__cta">
          <Button href="/made" variant="primary" arrow>See what we've made</Button>
          <Button href="#mantra" variant="ghost">Read our mantra</Button>
        </div>
      </div>
    </div>
  </div>
</section>
