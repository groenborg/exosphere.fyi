---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Eyebrow from "../../../components/Eyebrow.astro";
import TransmissionCard from "../../../components/transmissions/TransmissionCard.astro";

export async function getStaticPaths() {
  const all = await getCollection("transmissions", ({ data }) =>
    import.meta.env.PROD ? data.draft !== true : true
  );

  const tags = new Set<string>();
  for (const entry of all) {
    for (const tag of entry.data.tags) tags.add(tag);
  }

  return Array.from(tags).map((tag) => {
    const posts = all
      .filter((e) => e.data.tags.includes(tag))
      .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
    return { params: { tag }, props: { tag, posts } };
  });
}

const { tag, posts } = Astro.props;

const enriched = await Promise.all(
  posts.map(async (entry) => {
    const { remarkPluginFrontmatter } = await render(entry);
    return { entry, minutesRead: remarkPluginFrontmatter?.minutesRead as string | undefined };
  })
);
---
<BaseLayout
  title={`Exosphere — Transmissions tagged "${tag}"`}
  description={`Transmissions on the topic of ${tag}.`}
  currentPath="/transmissions"
  page="transmissions"
>
  <section class="tx-list-hero">
    <div class="wrap">
      <Eyebrow>{`Tag · ${tag} · ${posts.length} ${posts.length === 1 ? 'post' : 'posts'}`}</Eyebrow>
      <h1 class="tx-list-hero__title">
        On <em>{tag}</em>.
      </h1>
      <p class="tx-list-hero__lede">
        <a href="/transmissions/tags" style="color:var(--accent)">← All tags</a>
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="tx-list">
        {enriched.map(({ entry, minutesRead }) => (
          <TransmissionCard
            href={`/transmissions/${entry.id}`}
            title={entry.data.title}
            description={entry.data.description}
            pubDate={entry.data.pubDate}
            author={entry.data.author}
            tags={entry.data.tags}
            minutesRead={minutesRead}
            draft={entry.data.draft}
            heroImage={entry.data.heroImage}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
