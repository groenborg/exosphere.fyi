---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  order: number;
  updatedDate?: Date;
  draft?: boolean;
  heroImage?: string;
  prev?: { id: string; title: string; order: number } | null;
  next?: { id: string; title: string; order: number } | null;
}
const { title, description, order, updatedDate, draft, heroImage, prev, next } = Astro.props;

const pad = (n: number) => n.toString().padStart(2, '0');
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: '2-digit', year: 'numeric' });
---
<BaseLayout title={`${title} — Craft`} description={description} currentPath="/craft" page="craft">
  <article class="cr-post">
    <div class="wrap">
      <header class="cr-post__head">
        <div class="cr-post__num">№ {pad(order)}</div>
        <h1 class="cr-post__title">{title}</h1>
        <p class="cr-post__lede">{description}</p>
        {heroImage && (
          <div class="cr-post__hero">
            <img src={heroImage} alt="" />
          </div>
        )}
        {(updatedDate || draft) && (
          <div class="cr-post__meta">
            {updatedDate && <span>Updated {fmt(updatedDate)}</span>}
            {draft && <span class="cr-post__draft">Draft</span>}
          </div>
        )}
      </header>

      <div class="prose">
        <slot />
      </div>

      <nav class="cr-post__foot" aria-label="Craft navigation">
        <a class="cr-post__back" href="/craft">← All craft</a>
        <div class="cr-post__pager">
          {prev && (
            <a class="cr-post__pager-link cr-post__pager-link--prev" href={`/craft/${prev.id}`}>
              <span class="cr-post__pager-label">← Previous · {pad(prev.order)}</span>
              <span class="cr-post__pager-title">{prev.title}</span>
            </a>
          )}
          {next && (
            <a class="cr-post__pager-link cr-post__pager-link--next" href={`/craft/${next.id}`}>
              <span class="cr-post__pager-label">Next · {pad(next.order)} →</span>
              <span class="cr-post__pager-title">{next.title}</span>
            </a>
          )}
        </div>
      </nav>
    </div>
  </article>
</BaseLayout>
