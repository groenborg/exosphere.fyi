---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  tags: string[];
  minutesRead?: string;
  draft?: boolean;
  heroImage?: string;
}
const { title, description, pubDate, updatedDate, author, tags, minutesRead, draft, heroImage } =
  Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "long", day: "2-digit", year: "numeric" });
---
<BaseLayout title={`${title} — Transmissions`} description={description} currentPath="/transmissions">
  <article class="tx-post">
    <div class="wrap">
      <header class="tx-post__head">
        {tags.length > 0 && (
          <div class="tx-post__tags">
            {tags.map((tag) => (
              <a class="tx__tag" href={`/transmissions/tags/${tag}`}>{tag}</a>
            ))}
          </div>
        )}
        <h1 class="tx-post__title">{title}</h1>
        <p class="tx-post__lede">{description}</p>
        {heroImage && (
          <div class="tx-post__hero">
            <img src={heroImage} alt="" />
          </div>
        )}
        <div class="tx-post__byline">
          <span>{author}</span>
          <span class="tx-post__byline-sep">·</span>
          <span>{fmt(pubDate)}</span>
          {updatedDate && (<><span class="tx-post__byline-sep">·</span><span>Updated {fmt(updatedDate)}</span></>)}
          {draft && <span class="tx__draft">Draft</span>}
        </div>
      </header>

      <div class="prose">
        <slot />
      </div>

      <footer class="tx-post__foot">
        <a class="tx-post__back" href="/transmissions">← All transmissions</a>
      </footer>
    </div>
  </article>
</BaseLayout>
